# ── Alpaca (PAPER ONLY — the base URL is hard-asserted to be a paper endpoint) ──
ALPACA_API_KEY=your_paper_key_id
ALPACA_SECRET_KEY=your_paper_secret
# Must contain "paper-api.alpaca.markets". The bot refuses to start otherwise.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Congressional disclosure data source ──
# Quiver Quantitative free API key — sign up at https://www.quiverquant.com/account/signup
# (free tier, no credit card required). Covers both Senate and House.
QUIVERQUANT_API_KEY=your_quiverquant_api_key

# ── Slack incoming webhook (one channel) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Strategy tunables (sensible defaults shown) ──
# Max distinct positions held in the mirror portfolio.
MAX_POSITIONS=15
# Fraction of account equity to deploy (1.0 = fully invested).
INVESTED_FRACTION=0.95
# Relative drift (e.g. 0.20 = 20%) before an existing position is rebalanced.
REBALANCE_BAND=0.20
# Minimum disclosed trades in trailing 12mo for a member to be rankable.
MIN_TRADES=8
# Minimum distinct tickers in trailing 12mo for a member to be rankable.
MIN_TICKERS=4
# Disclosure reporting/data lookback window in days (covers the ~45-day STOCK Act lag).
LOOKBACK_DAYS=120
# DRY_RUN=true previews orders without submitting. Default-on for safety.
DRY_RUN=true
# FORCE_ORDERS=true submits orders even when the market is closed (testing only).
# FORCE_ORDERS=false
# Path to the SQLite state DB (use a persistent volume in production).
STATE_DB_PATH=state.db
